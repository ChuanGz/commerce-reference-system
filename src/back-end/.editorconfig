# top-most EditorConfig file
root = true

# All C# files
[*.cs]
charset = utf-8
indent_style = space
indent_size = 4
tab_width = 4
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = crlf

###########################
# C# Code Style Rules
###########################

# Use explicit types (avoid var)
dotnet_style_prefer_var_for_built_in_types = false:suggestion
dotnet_style_prefer_var_when_type_is_apparent = false:suggestion
dotnet_style_prefer_var_elsewhere = false:suggestion

# Avoid qualification (no "this." unless required)
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning
dotnet_style_qualification_for_local_variable = false:suggestion

# Expression and simplification preferences
dotnet_style_prefer_inferred_tuple_names = true:suggestion
dotnet_style_prefer_inferred_anonymous_type_member_names = true:suggestion
dotnet_style_prefer_compound_assignment = true:suggestion
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion
dotnet_style_prefer_conditional_expression_over_return = true:suggestion
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:warning
dotnet_style_prefer_throw_expression = true:suggestion

###########################
# Naming Rules
###########################

# Interface names start with I
dotnet_naming_rule.interface_should_be_prefixed_with_i.severity = warning
dotnet_naming_rule.interface_should_be_prefixed_with_i.symbols = interface
dotnet_naming_rule.interface_should_be_prefixed_with_i.style = prefix_i

dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.interface.applicable_accessibilities = *
dotnet_naming_symbols.interface.required_modifiers = *

dotnet_naming_style.prefix_i.required_prefix = I
dotnet_naming_style.prefix_i.capitalization = pascal_case

# Private fields prefixed with _
dotnet_naming_rule.private_fields_should_be_camel_case_with_underscore.severity = suggestion
dotnet_naming_rule.private_fields_should_be_camel_case_with_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_case_with_underscore.style = underscore_prefix_style

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_fields.required_modifiers = readonly

dotnet_naming_style.underscore_prefix_style.required_prefix = _
dotnet_naming_style.underscore_prefix_style.capitalization = camel_case

###########################
# Analyzer Rules (Production Critical)
###########################

# Code correctness and safety
dotnet_diagnostic.CA1062.severity = error     # Validate arguments of public methods
dotnet_diagnostic.CA1822.severity = error     # Mark members as static
dotnet_diagnostic.CA1801.severity = error     # Parameter never used
dotnet_diagnostic.CA2100.severity = error     # SQL security warning
dotnet_diagnostic.CA5350.severity = error     # Weak crypto
dotnet_diagnostic.CA5122.severity = error     # Unsafe deserialization
dotnet_diagnostic.CA1001.severity = error     # Dispose owned resources
dotnet_diagnostic.CA1501.severity = error     # Excessive inheritance
dotnet_diagnostic.CA1506.severity = warning   # Class coupling

# Nullability and async
dotnet_diagnostic.CS8602.severity = error     # Possible null dereference
dotnet_diagnostic.CS8618.severity = error     # Non-nullable property uninitialized
dotnet_diagnostic.CS1998.severity = warning   # Async method has no await

# Style violations
dotnet_diagnostic.IDE0051.severity = warning  # Remove unused private members
dotnet_diagnostic.IDE0060.severity = warning  # Remove unused parameters
dotnet_diagnostic.IDE0039.severity = suggestion # Use local function
dotnet_diagnostic.IDE0055.severity = suggestion # Formatting
dotnet_diagnostic.IDE1006.severity = error    # Naming rule violation

# Remove unnecessary usings
dotnet_diagnostic.RemoveUnnecessaryUsings.severity = warning

###########################
# File Layout
###########################

dotnet_sort_system_directives_first = true
file_header_template = Licensed under the MIT license.

###########################
# Formatting Rules
###########################

csharp_new_line_before_open_brace = all:warning
